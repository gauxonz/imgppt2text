# Cloudflare Pages 环境变量配置
# 复制此文件为 .env.local 并填入自己的配置
# 此文件会被 gitignore 忽略，不会提交到仓库

# 后端 Workers 地址（必需）
API_URL=https://your-workers.workers.dev/

# 阿里百炼 API 地址（可选，有默认值）
DEFAULT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型（可选，有默认值）
DEFAULT_MODEL=qwen3.5-plus

# 每周免费限额（可选，有默认值）
DEFAULT_WEEKLY_LIMIT=50
