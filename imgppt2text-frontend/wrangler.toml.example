# Cloudflare Pages 配置示例
# 复制此文件为 wrangler.toml 并修改

name = "imgppt2text-frontend"
compatibility_date = "2024-01-01"
pages_build_output_dir = "."

# 部署时设置的环境变量（构建时会替换到代码中）
# 在 Cloudflare Dashboard -> Pages -> 设置 -> 环境变量 中配置：
# API_URL: https://your-workers.workers.dev/
# DEFAULT_BASE_URL: https://dashscope.aliyuncs.com/compatible-mode/v1
# DEFAULT_MODEL: qwen3.5-plus
# DEFAULT_WEEKLY_LIMIT: 50
